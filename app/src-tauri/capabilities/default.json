{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://json.edhrec.com/*" },
        { "url": "https://api.scryfall.com/*" },
        { "url": "https://backend.commanderspellbook.com/*" }
      ]
    }
  ]
}
